# LightRAG configuration template.
# scripts/setup-lightrag.sh writes the real .env at ~/.lightrag/.env
# by substituting GEMINI_API_KEY from the server environment.
# Never put actual keys in this file — it is committed to the repo.

# LLM for entity extraction — Gemini 2.0 Flash (free tier, OpenAI-compatible endpoint)
LLM_BINDING=openai
LLM_MODEL=gemini-2.0-flash
LLM_BINDING_HOST=https://generativelanguage.googleapis.com/v1beta/openai
OPENAI_API_KEY=${GEMINI_API_KEY}

# Embedding — Gemini text-embedding-004 (free tier, same key, 768 dims)
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_BINDING_HOST=https://generativelanguage.googleapis.com/v1beta/openai
EMBEDDING_DIM=768
EMBEDDING_MAX_TOKEN_SIZE=2048

# Working directory — where LightRAG stores its graph and vector index
WORKING_DIR=${HOME}/.lightrag/data

# Server (localhost only — not exposed externally)
HOST=127.0.0.1
PORT=9621

# Keep RAM usage safe on a 2GB server
MAX_ASYNC=2
MAX_TOKENS=4096
ENABLE_LLM_CACHE=true
LIGHTRAG_LOG_LEVEL=WARNING
