# LightRAG configuration template.
# scripts/setup-lightrag.sh writes the real .env at ~/.lightrag/.env
# by substituting values from environment variables already on the server.
# Never put actual keys in this file — it is committed to the repo.

# LLM for entity extraction (Groq llama-3.3-70b — 70B, fast, OpenAI-compatible)
LLM_BINDING=openai
LLM_MODEL=llama-3.3-70b-versatile
LLM_BINDING_HOST=https://api.groq.com/openai/v1
OPENAI_API_KEY=${GROQ_API_KEY}

# Embedding (OpenAI text-embedding-3-small — already wired on this server)
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_API_KEY=${OPENAI_API_KEY}
EMBEDDING_DIM=1536
EMBEDDING_MAX_TOKEN_SIZE=8192

# Working directory — where LightRAG stores its graph and vector index
WORKING_DIR=${HOME}/.lightrag/data

# Server
HOST=127.0.0.1
PORT=9621

# Keep entity extraction lightweight on a 2GB server
MAX_ASYNC=2
MAX_TOKENS=4096

# Disable optional features that cost RAM
ENABLE_LLM_CACHE=true
LIGHTRAG_LOG_LEVEL=WARNING
